loadablesdir = @loadablesdir@

include $(loadablesdir)/Makefile.inc

INC += -I$(loadablesdir)

LOCAL_CFLAGS += -fanalyzer -Wreturn-type -Werror

SOURCES = $(wildcard *.c)
LOADABLES = $(SOURCES:.c=)
OBJECTS = $(SOURCES:.c=.o)

all:	$(LOADABLES)

$(LOADABLES): %: %.o
	$(SHOBJ_LD) $(SHOBJ_LDFLAGS) $(SHOBJ_XLDFLAGS) -o $@ $< $(SHOBJ_LIBS)

check:	all test

test:	$(LOADABLES)
	$${THIS_SH:-bash} test/defer_test.sh

format:
	indent -gnu $(SOURCES)

clean:
	$(RM) $(OBJECTS) $(LOADABLES)

distclean: clean
	$(RM) Makefile config.log config.status
	$(RM) -r autom4te.cache

.PHONY:	all check test format clean distclean